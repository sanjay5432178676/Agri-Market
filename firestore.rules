rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: lock down by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isParticipant(convoId) {
      return isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(convoId)).data.participants);
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      // Allow user to manage their own profile
      allow write: if isOwner(userId);
      
      // Allow others to update aggregate rating/reviewCount when they leave a review
      allow update: if isSignedIn() && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviewCount']);

      // User Reviews
      match /reviews/{reviewId} {
        allow read: if true;
        // Anyone signed in can create a review for someone else
        allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid;
        // User can delete their own reviews
        allow delete: if isSignedIn() && resource.data.fromUserId == request.auth.uid;
      }

      // User Wishlist
      match /wishlist/{listingId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Listings Collection
    match /listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn();
      // Only the owner (farmer) can update or delete their listing
      allow update, delete: if isSignedIn() && resource.data.farmerId == request.auth.uid;
    }

    // Mandi Prices (Read-only for public)
    match /mandiPrices/{priceId} {
      allow read: if true;
    }

    // Conversations & Chat
    match /conversations/{convoId} {
      // Participants can read and update the conversation metadata
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants);
      
      // Anyone signed in can start a conversation
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participants);
      
      // Participants can update conversation metadata (e.g., lastMessage, timestamps, unreadCount)
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants);
      
      // Messages Sub-collection
      match /messages/{messageId} {
        // Participants of the parent conversation can read, create, and update message status
        allow read: if isParticipant(convoId);
        allow create: if isParticipant(convoId) && request.resource.data.senderId == request.auth.uid;
        
        // Allow updating message status (isRead, isDelivered)
        allow update: if isParticipant(convoId) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'isDelivered']);
      }
    }
  }
}
